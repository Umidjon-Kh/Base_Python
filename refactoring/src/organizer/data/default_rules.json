{
    "other_behavior": "use_other",
    "ignore_extensions": [".tmp", ".log", ".bak"],
    "rules": [
        {
            "type": "extension",
            "extensions": [".txt", ".md"],
            "folder": "Documents"
        },
        {
            "type": "extension",
            "extensions": [".jpg", ".png"],
            "folder": "Images"
        }
    ]
}