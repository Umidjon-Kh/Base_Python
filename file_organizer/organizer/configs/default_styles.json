{
    "console": {
        "minimalistic": "<green>{time:HH:mm:ss}</green> | <level>{message}</level>",
        "simple": "<level>{level: <8}</level> | <cyan>{name}</cyan> | <level>{message}</level>",
        "modern": "<fg #808080>[</fg #808080><level>{level: <8}</level><fg #808080>]</fg #808080> <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> | <level>{message}</level>",
        "box": "<fg #808080>┌─[</fg #808080><level>{level: <8}</level><fg #808080>]─[</fg #808080><cyan>{name}</cyan><fg #808080>]</fg #808080>\n│ <level>{message}</level>\n<fg #808080>└─[{time:HH:mm:ss}]</fg #808080>",
        "arrow": "<level>{level: <8}</level> <fg #808080>➤</fg #808080> <cyan>{name}</cyan> <fg #808080>➤</fg #808080> <level>{message}</level> <fg #808080>({time:HH:mm:ss})</fg #808080>",
        "compact": "<level>{level:.1}</level> <cyan>{name}</cyan> | <level>{message}</level>",
        "colored": "<red>{time:HH:mm:ss}</red> <yellow>|</yellow> <blue>{level: <8}</blue> <yellow>|</yellow> <magenta>{name}</magenta> <yellow>|</yellow> <cyan>{message}</cyan>",
        "emoji": "{level.icon} <cyan>{name}</cyan> | <level>{message}</level>"
    },
    "file": {
        "minimalistic": "{time:HH:mm:ss} | {message}",
        "simple": "{time:YYYY-MM-DD HH:mm:ss} | {level: <8} | {name} | {message}",
        "modern": "{time:YYYY-MM-DD HH:mm:ss} | {level: <8} | {name}.{function}:{line} | {message}",
        "box": "{time:HH:mm:ss} | {level} | {name} | {message}",
        "arrow": "{time:HH:mm:ss} | {level} | {name} | {message}",
        "compact": "{time:HH:mm:ss} | {level:.1} | {name} | {message}",
        "colored": "{time:HH:mm:ss} | {level} | {name} | {message}",
        "emoji": "{time:HH:mm:ss} | {level} | {name} | {message}"
    }
}