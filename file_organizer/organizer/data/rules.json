{
    "other_behavior": "use_other",
    "ignore_extensions": [".tmp", ".temp", ".part", ".crdownload"],
    "ignore_size_more_than": 2147483648,
    "ignore_size_less_than": null,
    "rules": [
        {
            "type": "extension",
            "extensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".svg", ".ico", ".tiff", ".heic", ".raw"],
            "folder": "Images",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".mpeg", ".3gp"],
            "folder": "Videos",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".mp3", ".wav", ".flac", ".aac", ".ogg", ".wma", ".m4a", ".opus"],
            "folder": "Audio",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".pdf", ".doc", ".docx", ".odt", ".rtf", ".tex", ".md", ".txt", ".epub"],
            "folder": "Documents",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".xls", ".xlsx", ".ods", ".csv"],
            "folder": "Spreadsheets",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".ppt", ".pptx", ".odp", ".key"],
            "folder": "Presentations",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".zip", ".tar", ".gz", ".bz2", ".xz", ".rar", ".7z", ".iso", ".dmg"],
            "folder": "Archives",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".py", ".js", ".ts", ".html", ".css", ".java", ".c", ".cpp", ".h",
                           ".cs", ".go", ".rs", ".rb", ".php", ".swift", ".kt", ".sh", ".bash",
                           ".json", ".yaml", ".yml", ".toml", ".xml", ".sql"],
            "folder": "Code",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".exe", ".msi", ".deb", ".rpm", ".apk", ".AppImage", ".bin"],
            "folder": "Executables",
            "priority": 0
        },
        {
            "type": "extension",
            "extensions": [".ttf", ".otf", ".woff", ".woff2", ".eot"],
            "folder": "Fonts",
            "priority": 0
        }
    ]
}