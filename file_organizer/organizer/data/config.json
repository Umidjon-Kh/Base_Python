{
    "source_dir": "~/Pictures",
    "dest_dir": "~/Pictures/Organized",
    "dry_run": false,
    "recursive": true,
    "ignore_patterns": [".tmp", "*.log", "*.bak"],
    "rules_file": "rules.json",
    "styles_file": "styles.json",
    "logging": {
        "console": {
            "enabled": true,
            "level": "INFO"
        },
        "file": {
            "enabled": true,
            "level": "DEBUG",
            "path": "logs/organizer.log",
            "rotation": "1 day",
            "retention": "7 days"
        }
    }
}